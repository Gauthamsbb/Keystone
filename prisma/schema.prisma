generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id            String           @id
  email         String           @unique
  role          String           @default("user")
  created_at    DateTime         @default(now())
  auditLogs     AdminAuditLog[]
  changeLogs    HabitChangeLog[]
  habitSections HabitSection[]
  habits        Habit[]
  rewardBuckets RewardBucket[]

  @@map("profiles")
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  user_id    String
  action     String
  table_name String
  record_id  String
  details    Json?
  created_at DateTime @default(now())
  user       Profile  @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([created_at])
  @@map("admin_audit_logs")
}

model Habit {
  id                  String        @id @default(uuid())
  name                String
  is_active           Boolean       @default(true)
  weekly_quota        Int
  input_schema        Json
  completion_field_id Int?
  completion_limit    Json?
  timing_field_id     Int?
  display_order       Int           @default(0)
  subtitle            String?
  user_id             String
  bucketHabits        BucketHabit[]
  entries             Entry[]
  user                Profile       @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@map("habits")
}

model HabitSection {
  id            String  @id @default(uuid())
  title         String
  subtitle      String?
  display_order Int     @default(0)
  user_id       String
  user          Profile @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@map("habit_sections")
}

model HabitChangeLog {
  id         String   @id @default(uuid())
  habit_id   String?
  habit_name String
  event      String
  details    Json?
  created_at DateTime @default(now())
  user_id    String?
  user       Profile? @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("habit_change_logs")
}

model Entry {
  id       String       @id @default(uuid())
  habit_id String
  date     DateTime     @db.Date
  habit    Habit        @relation(fields: [habit_id], references: [id], onDelete: Cascade)
  values   EntryValue[]

  @@unique([habit_id, date])
  @@map("entries")
}

model EntryValue {
  id            String   @id @default(uuid())
  entry_id      String
  field_id      Int
  text_value    String?
  int_value     Int?
  duration_mins Int?
  time_mins     Int?
  boolean_value Boolean?
  entry         Entry    @relation(fields: [entry_id], references: [id], onDelete: Cascade)

  @@unique([entry_id, field_id])
  @@map("entry_values")
}

model RewardBucket {
  id            String            @id @default(uuid())
  name          String
  description   String?
  display_order Int               @default(0)
  created_at    DateTime          @default(now())
  user_id       String
  habits        BucketHabit[]
  milestones    BucketMilestone[]
  user          Profile           @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@map("reward_buckets")
}

model BucketHabit {
  id        String       @id @default(uuid())
  bucket_id String
  habit_id  String
  bucket    RewardBucket @relation(fields: [bucket_id], references: [id], onDelete: Cascade)
  habit     Habit        @relation(fields: [habit_id], references: [id], onDelete: Cascade)

  @@unique([bucket_id, habit_id])
  @@map("bucket_habits")
}

model BucketMilestone {
  id            String       @id @default(uuid())
  bucket_id     String
  streak_target Int
  reward        String
  display_order Int          @default(0)
  bucket        RewardBucket @relation(fields: [bucket_id], references: [id], onDelete: Cascade)

  @@map("bucket_milestones")
}
